#!/usr/bin/env bash
set -euo pipefail

# BEGIN wordpress-github-updater
# Keeps GitHubUpdater.php and release.yml up to date from the upstream repo.
#
# - GitHubUpdater.php  -> includes/GitHubUpdater.php   (or UPDATER_DEST in config)
# - release.yml        -> .github/workflows/release.yml (or RELEASE_DEST in config)
#
# Install as a Git pre-commit hook:
#   cp pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or run manually at any time from your project root:
#   bash pre-commit
#
# Optional config file (.githubupdater.conf in repo root):
#   UPDATER_DEST=<path>     destination relative to repo root (default: includes/GitHubUpdater.php)
#   RELEASE_DEST=<path>     destination relative to repo root (default: .github/workflows/release.yml)

BASE_URL="https://raw.githubusercontent.com/stehardy775/wordpress-github-updater/main"

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Defaults
UPDATER_SRC="${BASE_URL}/GitHubUpdater.php"
UPDATER_DEST="includes/GitHubUpdater.php"
RELEASE_SRC="${BASE_URL}/release.yml"
RELEASE_DEST=".github/workflows/release.yml"

# Load optional config
CONFIG_FILE="${REPO_ROOT}/.githubupdater.conf"
if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

download() {
  local src="$1"
  local dest="${REPO_ROOT}/$2"
  echo "Downloading: ${src}"
  echo "         -> ${2}"
  mkdir -p "$(dirname "$dest")"
  curl -fsSL "$src" -o "$dest"
}

download "$UPDATER_SRC" "$UPDATER_DEST"
download "$RELEASE_SRC" "$RELEASE_DEST"

# Optionally install this script as the repo's pre-commit hook so the files
# stay up to date on every commit. Enable by setting INSTALL_HOOK=1, e.g.:
#   curl -fsSL <url>/pre-commit | INSTALL_HOOK=1 bash
# Running as the hook itself does not set INSTALL_HOOK, so there is no
# re-install loop on commit.
if [[ "${INSTALL_HOOK:-}" == "1" ]]; then
  HOOK_PATH="$(git rev-parse --git-path hooks/pre-commit)"
  mkdir -p "$(dirname "$HOOK_PATH")"

  TMP_HOOK="$(mktemp)"
  curl -fsSL "${BASE_URL}/pre-commit" -o "$TMP_HOOK"

  if [[ ! -f "$HOOK_PATH" ]]; then
    cp "$TMP_HOOK" "$HOOK_PATH"
    echo "Installed pre-commit hook -> ${HOOK_PATH}"
  elif grep -qF '# BEGIN wordpress-github-updater' "$HOOK_PATH"; then
    echo "pre-commit hook already contains the updater block; left unchanged."
  elif head -1 "$HOOK_PATH" | grep -qE '^#!.*/(env +)?(bash|sh)( |$)' \
       && ! grep -qiE 'husky|pre-commit\.com|lefthook|generated by pre-commit' "$HOOK_PATH"; then
    # Existing hook is a plain shell script and not managed by another tool:
    # safe to extend. Append our block (skipping the shebang) to preserve it.
    tail -n +2 "$TMP_HOOK" >> "$HOOK_PATH"
    echo "Appended updater block to existing pre-commit hook."
  else
    # Foreign / tool-managed / non-shell hook: do not touch it.
    echo "Existing pre-commit hook looks managed by another tool (or isn't a"
    echo "shell script); leaving it untouched to avoid breaking it."
    echo "To keep the files updated, run this on demand, or wire it into your"
    echo "own hook/CI:"
    echo "  curl -fsSL ${BASE_URL}/pre-commit | bash"
  fi

  chmod +x "$HOOK_PATH"
  rm -f "$TMP_HOOK"

  # Seed a config file the user can edit, without clobbering an existing one.
  CONF_PATH="${REPO_ROOT}/.githubupdater.conf"
  if [[ ! -f "$CONF_PATH" ]]; then
    curl -fsSL "${BASE_URL}/.githubupdater.conf" -o "$CONF_PATH"
    echo "Created .githubupdater.conf (edit to configure paths/packaging)."
  else
    echo ".githubupdater.conf already exists; left unchanged."
  fi
fi

echo "Done."
# END wordpress-github-updater