# GitHubUpdater proxy — configuration
#
# On Azure App Service these are set as "Application settings" (Settings →
# Environment variables), NOT committed. This file documents the keys only.

# --- Core -------------------------------------------------------------------

# Required — fine-grained PAT with Contents:Read on the private repo(s).
# This is the real bound on what the proxy can serve, so scope it tightly.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# Recommended — shared secret. The plugin sends it as X-GHU-Key; the proxy
# rejects proxy requests without a match. When unset, the proxy is open.
GHU_SHARED_SECRET=change-me-to-a-long-random-string

# --- Logging (write) — Log Analytics custom table ---------------------------
# When unset, logging is skipped and the proxy still serves updates.
# Auth uses the web app's managed identity (no secret here).
LOGS_DCE_ENDPOINT=https://<dce-name>.<region>-1.ingest.monitor.azure.com
LOGS_DCR_RULE_ID=dcr-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LOGS_STREAM_NAME=Custom-GhuRequests_CL

# --- Dashboard (read) — Log Analytics workspace -----------------------------
# Workspace GUID. Identity needs "Log Analytics Reader" on the workspace.
LOGS_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# --- Blocklist + settings store — Azure Table Storage -----------------------
# Storage account name only. Identity needs "Storage Table Data Contributor".
# When unset, the blocklist is disabled (nothing is blocked).
GHU_STORAGE_ACCOUNT=yourstorageacct

# --- Admin access -----------------------------------------------------------
# Optional. Comma-separated Entra principal names (emails) allowed into /admin.
# When unset, any user who passes Easy Auth may access the admin pages.
GHU_ADMINS=you@example.com,colleague@example.com
